{
    "name": "carenest/senior-care",
    "version": "1.0.0",
    "description": "CareNest senior care web app",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "classmap": [
            "config/",
            "models/",
            "models/patterns/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "CareNest\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit --configuration phpunit.xml.dist"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}
